clean: compiler_clean 
	-$(DEL_FILE) debug\ccb.obj debug\delegate.obj debug\error.obj debug\ini_save.obj debug\main.obj debug\mainwindow.obj debug\shutdown.obj debug\sql.obj debug\tip.obj debug\vscode.obj debug\website.obj debug\fakecmd_plugin_import.obj debug\moc_delegate.obj debug\moc_mainwindow.obj
	-$(DEL_FILE) debug\fakeCmd.vc.pdb debug\fakeCmd.ilk debug\fakeCmd.idb
	-$(DEL_FILE) debug\icon.res

distclean: clean 
	-$(DEL_FILE) C:\code\fakeCmd\fakecmd_plugin_import.cpp .qmake.stash debug\fakeCmd.pdb
	-$(DEL_FILE) $(DESTDIR_TARGET)
	-$(DEL_FILE) Makefile.Debug

